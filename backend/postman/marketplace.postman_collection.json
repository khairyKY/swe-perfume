{
  "info": {
    "name": "Marketplace API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000" },
    { "key": "userToken", "value": "" },
    { "key": "vendorToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "applicationId", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user1@test.local\",\n  \"password\": \"Password123!\",\n  \"name\": \"User One\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user1@test.local\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "me"]
            }
          }
        },
        {
          "name": "Delete Me",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "me"]
            }
          }
        },
        {
          "name": "Apply Vendor",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/vendor-apply",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "vendor-apply"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"brandName\": \"My Brand\",\n  \"bio\": \"Bio\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Product By Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "{{productId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Vendor Products",
      "item": [
        {
          "name": "Create Product (Image URL)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{vendorToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/vendor/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "vendor", "products"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Item\",\n  \"description\": \"Item description\",\n  \"price\": 25,\n  \"imageUrl\": \"https://example.com/image.jpg\"\n}"
            }
          }
        },
        {
          "name": "Create Product (File Upload)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{vendorToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/vendor/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "vendor", "products"]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Item", "type": "text" },
                {
                  "key": "description",
                  "value": "Item description",
                  "type": "text"
                },
                { "key": "price", "value": "25", "type": "text" },
                { "key": "image", "type": "file" }
              ]
            }
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{vendorToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/vendor/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "vendor", "products", "{{productId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Item\",\n  \"price\": 30\n}"
            }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{vendorToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/vendor/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "vendor", "products", "{{productId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [{\n    \"productId\": \"{{productId}}\",\n    \"quantity\": 1\n  }],\n  \"shippingAddress\": {\n    \"street\": \"123 Lane\",\n    \"city\": \"Town\",\n    \"zip\": \"00000\",\n    \"country\": \"US\"\n  }\n}"
            }
          }
        },
        {
          "name": "List My Orders",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/orders/my-orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "my-orders"]
            }
          }
        },
        {
          "name": "Get Order By Id",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/orders/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "{{orderId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Vendor Orders",
      "item": [
        {
          "name": "List Vendor Orders",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{vendorToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/vendor/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "vendor", "orders"]
            }
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{vendorToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/vendor/orders/{{orderId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "vendor", "orders", "{{orderId}}", "status"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"shipped\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "List Applications",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/applications?status=pending",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "applications"],
              "query": [{ "key": "status", "value": "pending" }]
            }
          }
        },
        {
          "name": "Approve Application",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/applications/{{applicationId}}/approve",
              "host": ["{{baseUrl}}"],
              "path": [
                "api",
                "admin",
                "applications",
                "{{applicationId}}",
                "approve"
              ]
            }
          }
        },
        {
          "name": "Reject Application",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/applications/{{applicationId}}/reject",
              "host": ["{{baseUrl}}"],
              "path": [
                "api",
                "admin",
                "applications",
                "{{applicationId}}",
                "reject"
              ]
            }
          }
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "users"]
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "users", "{{userId}}"]
            }
          }
        },
        {
          "name": "Admin Remove Product",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "products", "{{productId}}"]
            }
          }
        }
      ]
    }
  ]
}
